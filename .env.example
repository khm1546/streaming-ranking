# ============================================
# Database (Supabase Postgres - Connection pooler)
# ============================================
# Project Settings → Database → Connection string → "Transaction" mode (port 6543)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# 같은 메뉴의 "Session" 모드 (port 5432) — Prisma 마이그레이션용
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres"

# ============================================
# Supabase API (Project Settings → API Keys)
# ============================================
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"

# Publishable key (sb_publishable_...) — 브라우저 노출 OK
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxxxx"

# Secret key (sb_secret_...) — 서버 전용, 절대 클라이언트 노출 금지
SUPABASE_SECRET_KEY="sb_secret_xxxxx"

# ============================================
# Kakao OAuth (Supabase Auth Provider 또는 직접 구현)
# ============================================
KAKAO_CLIENT_ID=""
KAKAO_CLIENT_SECRET=""

# ============================================
# Google OAuth
# ============================================
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ============================================
# Storage
# ============================================
STORAGE_BUCKET="streaming-proofs"

# ============================================
# Admin
# ============================================
ADMIN_ALLOWED_EMAILS="hyeongmin.kim@emotion.co.kr"
